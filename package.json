    "autoprefixer": "^10.4.21",
    "csv-parse": "^6.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
