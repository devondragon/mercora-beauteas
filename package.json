{
  "name": "mercora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:dev": "npm run clean && opennextjs-cloudflare build && opennextjs-cloudflare deploy --env dev",
    "predeploy:production": "if [ ! -f wrangler.jsonc ]; then echo 'ERROR: wrangler.jsonc not found.' >&2; exit 1; fi; if grep -q 'REPLACE_WITH_' wrangler.jsonc; then echo 'ERROR: wrangler.jsonc contains REPLACE_WITH_ placeholder(s). Fill in live keys before deploying to production.' >&2; exit 1; fi",
    "deploy:production": "npm run clean && opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
    "clean": "rm -rf .open-next .next .wrangler/state .wrangler/public",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "preview:dev": "opennextjs-cloudflare build && wrangler dev --env dev",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "token:generate": "tsx scripts/manage-tokens.ts generate",
    "token:list": "tsx scripts/manage-tokens.ts list",
    "token:revoke": "tsx scripts/manage-tokens.ts revoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@clerk/themes": "^2.4.0",
    "@cloudflare/workers-types": "^4.20250726.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "@react-email/components": "^0.4.0",
    "@react-email/render": "^1.1.4",
    "@shadcn/ui": "^0.0.4",
    "@stripe/react-stripe-js": "^3.9.0",
    "@stripe/stripe-js": "^7.8.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-character-count": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/html": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/sanitize-html": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.18.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.525.0",
    "marked": "^16.3.0",
    "nanoid": "^5.1.6",
    "next": "^15.5.19",
    "novel": "^1.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "resend": "^4.8.0",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "sonner": "^2.0.6",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.6"
